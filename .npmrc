# ツールフォルダ（tools/<slug>/）は意図的に package.json を持たない（tool-scaffold のアナトミー参照）。
# その ui.tsx は react を import し、apps/hub にバンドル＆型チェックされる。
# pnpm の隔離 node_modules だと tools/* から react 系が解決できないため、root の node_modules に hoist する。
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
public-hoist-pattern[]=@types/react
public-hoist-pattern[]=@types/react-dom

# 非対話（エージェント/CI）で hoist 設定変更時の node_modules 再作成を確認なしで進める
confirm-modules-purge=false
